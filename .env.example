# Database
DB_NAME=appdb
DB_USER=app
DB_PASSWORD=changeme_in_production
DB_PORT=5432
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Application
SERVER_PORT=8000
SECRET_KEY=changeme_generate_a_secure_random_string_at_least_256_bits
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
APP_ENV=development
DOCS_ENABLED=true

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Password hashing
BCRYPT_ROUNDS=12

# Circuit breaker
CB_FAILURE_THRESHOLD=5
CB_OPEN_DURATION_SECONDS=30

# Database pool
DB_POOL_SIZE=5

# Gunicorn (production)
GUNICORN_WORKERS=4
